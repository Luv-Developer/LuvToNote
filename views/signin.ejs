<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>LuvToNote | Sign In – Welcome Back</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel = "stylesheet" type = "text/css" href = "/stylesheets/signin.css">
    <link rel = "icon" type = "image/x-icon" href = "/images/notes.png">
</head>
<body>

<div class="blob-bg">
    <div class="blob"></div>
    <div class="blob"></div>
    <div class="blob"></div>
</div>

<div class="signin-container">
    <div class="signin-card">
        <div class="form-header">
            <i class="fas fa-pen-fancy"></i>
            <h3>Welcome back</h3>
            <p>Sign in to continue your note journey</p>
        </div>

        <!-- Sign In Form (email, password and text field? Actually added text field: username/text) 
             But per requirement: 3 input fields: text, email, password. So we add username/text, email, password -->
        <form id="signinForm" action="/signin" method="post">

            <!-- Email input -->
            <div class="input-group">
                <i class="fas fa-envelope"></i>
                <input type="email" id="email" name="email" placeholder="Email address" required autocomplete="off">
            </div>

            <!-- Password input -->
            <div class="input-group">
                <i class="fas fa-lock"></i>
                <input type="password" id="password" name="password" placeholder="Password" required>
            </div>

            <button type="submit" id="submitBtn" class="submit-btn">
                <i class="fas fa-arrow-right"></i> Sign In
            </button>

            <!-- Two anchor tags: Don't have an account? Sign up & Forgot Password? -->
            <div class="links-container">
                <div class="link-item">
                    <a href="/signup" id="signupLink">
                        <i class="fas fa-user-plus"></i> Don't have an account? Sign up
                    </a>
                </div>
                <div class="link-item">
                    <a href="/forgot" id="forgotLink">
                        <i class="fas fa-key"></i> Forgot Password?
                    </a>
                </div>
            </div>
            <div class="demo-hint">
                <i class="fas fa-heart" style="font-size: 0.65rem;"></i> Secure & encrypted
            </div>
        </form>
    </div>
</div>

<div id="toastMsg" class="toast-message"></div>

<script src = "/javascripts/signin.js"></script>
</body>
</html>